# ============================================================================
# Example configuration
# ============================================================================
# Copy this file to `.env` and fill in the values you actually use.
#
# Recommended approach:
# 1. Configure the minimum block below
# 2. Add only the optional sections you need


# ============================================================================
# Minimum setup required
# ============================================================================
# Main provider: gemini | openai | glm | openrouter
AI_CORRECTION_AI_PROVIDER=

# Configure at least the API key matching the provider above
AI_CORRECTION_GEMINI_API_KEY=
# AI_CORRECTION_OPENAI_API_KEY=
# AI_CORRECTION_GLM_API_KEY=
# AI_CORRECTION_OPENROUTER_API_KEY=

# Local storage
AI_CORRECTION_DATA_DIR=data


# ============================================================================
# Provider models
# ============================================================================
# Only uncomment the provider(s) you use.

# Gemini
# AI_CORRECTION_GEMINI_MODEL=
# AI_CORRECTION_GEMINI_VISION_MODEL=
# AI_CORRECTION_GEMINI_EMBEDDING_MODEL=

# OpenAI
# AI_CORRECTION_OPENAI_MODEL=
# AI_CORRECTION_OPENAI_VISION_MODEL=
# AI_CORRECTION_OPENAI_EMBEDDING_MODEL=

# GLM
# AI_CORRECTION_GLM_MODEL=
# AI_CORRECTION_GLM_VISION_MODEL=

# OpenRouter
# AI_CORRECTION_OPENROUTER_MODEL=
# AI_CORRECTION_OPENROUTER_VISION_MODEL=


# ============================================================================
# Dual-LLM grading (optional)
# ============================================================================
# Enable if you want cross-checking between 2 models.
AI_CORRECTION_COMPARISON_MODE=false
# AI_CORRECTION_LLM1_PROVIDER=
# AI_CORRECTION_LLM1_MODEL=
# AI_CORRECTION_LLM2_PROVIDER=
# AI_CORRECTION_LLM2_MODEL=


# ============================================================================
# PDF annotation (optional)
# ============================================================================
# If unset, the app still generates annotated PDFs and overlays
# with heuristic placement.
# AI_CORRECTION_ANNOTATION_PROVIDER=
# AI_CORRECTION_ANNOTATION_MODEL=


# ============================================================================
# Review context for disagreements (optional)
# ============================================================================
# Dedicated model to enrich disagreement cards with extra context.
# AI_CORRECTION_REVIEW_CONTEXT_PROVIDER=
# AI_CORRECTION_REVIEW_CONTEXT_MODEL=


# ============================================================================
# Confidence thresholds
# ============================================================================
AI_CORRECTION_CONFIDENCE_AUTO=0.85
AI_CORRECTION_CONFIDENCE_FLAG=0.60


# ============================================================================
# Email (optional)
# ============================================================================
# SENDGRID_API_KEY=
# AI_CORRECTION_SENDGRID_SENDER=no-reply@example.com
# AI_CORRECTION_SENDGRID_SANDBOX_MODE=false


# ============================================================================
# Observability (optional)
# ============================================================================
# AI_CORRECTION_SENTRY_DSN=
# AI_CORRECTION_SENTRY_ENVIRONMENT=development
# AI_CORRECTION_SENTRY_TRACES_SAMPLE_RATE=0.1


# ============================================================================
# Advanced toggles (optional)
# ============================================================================
# AI_CORRECTION_ENABLE_PROMPT_CACHING=true
# AI_CORRECTION_CACHE_TTL_SECONDS=300
# AI_CORRECTION_USE_EXPLICIT_CACHE=true
# AI_CORRECTION_FLIP_FLOP_THRESHOLD=0.0
